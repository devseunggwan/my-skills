#!/bin/bash
# cmux-session-status — Display cmux session status dashboard (bash 3.2 compatible)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cmux-session-lib"
preflight_check || exit 1
scan_workspaces

# --- Detect states and classify ---
detect_and_classify_all

count_active=0; count_waiting=0; count_idle=0; count_crashed=0; count_unknown=0
i=0
while [[ $i -lt $WS_COUNT ]]; do
  case "$(ws_get $i $_STATE)" in
    ACTIVE)  count_active=$((count_active + 1)) ;;
    WAITING) count_waiting=$((count_waiting + 1)) ;;
    IDLE)    count_idle=$((count_idle + 1)) ;;
    CRASHED) count_crashed=$((count_crashed + 1)) ;;
    *)       count_unknown=$((count_unknown + 1)) ;;
  esac
  i=$((i + 1))
done

# --- Find orphans ---
find_orphans

safe_numeric_names=(); named_orphan_names=(); unsafe_orphan_names=()
count_safe=0; count_named=0; count_unsafe=0

j=0
while [[ $j -lt $ORPHAN_COUNT ]]; do
  local_entry="${ORPHAN_DATA[$j]}"
  oname=$(echo "$local_entry" | cut -d'|' -f1)
  otype=$(echo "$local_entry" | cut -d'|' -f2)
  ocmds=$(echo "$local_entry" | cut -d'|' -f3)

  case "$otype" in
    safe_numeric)  safe_numeric_names+=("$oname"); count_safe=$((count_safe + 1)) ;;
    safe_named)    named_orphan_names+=("$oname"); count_named=$((count_named + 1)) ;;
    unsafe_*)      unsafe_orphan_names+=("$oname ($ocmds)"); count_unsafe=$((count_unsafe + 1)) ;;
  esac
  j=$((j + 1))
done

total_orphan=$((count_safe + count_named + count_unsafe))

# --- Output: Summary ---
echo ""
echo "=== cmux Session Status ==="
printf "Active: %d | Waiting: %d | Idle: %d | Crashed: %d | Orphaned: %d" \
  "$count_active" "$count_waiting" "$count_idle" "$count_crashed" "$total_orphan"
if [[ $total_orphan -gt 0 ]]; then
  printf " (%d auto + %d named + %d unsafe)" "$count_safe" "$count_named" "$count_unsafe"
fi
echo ""
echo ""

# --- Output: Workspace Table ---
printf "%-10s %-6s %-50s %-25s\n" "STATE" "CAT" "NAME" "BRANCH"
printf "%-10s %-6s %-50s %-25s\n" "-----" "---" "----" "------"

i=0
while [[ $i -lt $WS_COUNT ]]; do
  ref=$(ws_get $i $_REF)
  local_state=$(ws_get $i $_STATE)
  local_cat=$(ws_get $i $_CAT)
  local_name=$(ws_get $i $_NAME)
  local_branch=$(ws_get $i $_BRANCH)

  local_icon=$(state_icon "$local_state")

  # Mark current workspace
  ws_num="${ref#workspace:}"
  if [[ "$ws_num" == "$CURRENT_WS" ]] || [[ "$ref" == "$CURRENT_WS" ]]; then
    local_icon="★current"
  fi

  # Truncate long strings
  if [[ ${#local_name} -gt 48 ]]; then
    local_name="${local_name:0:45}..."
  fi
  if [[ ${#local_branch} -gt 23 ]]; then
    local_branch="${local_branch:0:20}..."
  fi

  printf "%-10s %-6s %-50s %-25s\n" "$local_icon" "$local_cat" "$local_name" "$local_branch"
  i=$((i + 1))
done

# --- Output: Orphan Section ---
if [[ $total_orphan -gt 0 ]]; then
  echo ""
  echo "ORPHANED TMUX SESSIONS:"
  if [[ ${#safe_numeric_names[@]} -gt 0 ]]; then
    echo "  ✗ auto-removable (shell-only): $(IFS=', '; echo "${safe_numeric_names[*]}") (${#safe_numeric_names[@]} sessions)"
  fi
  for n in "${named_orphan_names[@]}"; do
    echo "  ⚠ named (requires confirm): $n"
  done
  for n in "${unsafe_orphan_names[@]}"; do
    echo "  ⚠ running processes: $n"
  done
fi

echo ""
