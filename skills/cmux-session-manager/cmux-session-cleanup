#!/bin/bash
# cmux-session-cleanup — 3-phase session cleanup with jq-safe JSON (bash 3.2 compatible)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/cmux-session-lib"

DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

preflight_check || exit 1
scan_workspaces

# --- Detect states and classify ---
detect_and_classify_all

find_orphans

is_current_ws() {
  local ref="$1"
  local ws_num="${ref#workspace:}"
  [[ "$ws_num" == "$CURRENT_WS" ]] || [[ "$ref" == "$CURRENT_WS" ]]
}

# === PHASE 1: Auto cleanup (jq-constructed JSON) ===
phase1_actions="[]"

j=0
while [[ $j -lt $ORPHAN_COUNT ]]; do
  entry="${ORPHAN_DATA[$j]}"
  oname=$(echo "$entry" | cut -d'|' -f1)
  otype=$(echo "$entry" | cut -d'|' -f2)
  ocmds=$(echo "$entry" | cut -d'|' -f3)

  if [[ "$otype" == "safe_numeric" ]]; then
    executed=false
    if [[ "$DRY_RUN" == "false" ]]; then
      if tmux kill-session -t "$oname" 2>/dev/null; then
        executed=true
      fi
    fi
    phase1_actions=$(echo "$phase1_actions" | jq \
      --arg s "$oname" --arg t "$otype" --argjson e "$executed" --argjson d "$DRY_RUN" \
      '. += [{"action":"kill_orphan","session":$s,"type":$t,"executed":$e,"dry_run":$d}]')
  else
    phase1_actions=$(echo "$phase1_actions" | jq \
      --arg s "$oname" --arg t "$otype" --arg c "$ocmds" \
      '. += [{"action":"report_orphan","session":$s,"type":$t,"commands":$c,"auto_delete":false}]')
  fi
  j=$((j + 1))
done

# Crashed workspaces
i=0
while [[ $i -lt $WS_COUNT ]]; do
  ref=$(ws_get $i $_REF)
  local_state=$(ws_get $i $_STATE)
  local_name=$(ws_get $i $_NAME)

  if is_current_ws "$ref"; then
    i=$((i + 1)); continue
  fi

  if [[ "$local_state" == "CRASHED" ]]; then
    executed=false
    if [[ "$DRY_RUN" == "false" ]]; then
      if cmux close-workspace --workspace "$ref" 2>/dev/null; then
        executed=true
      fi
    fi
    phase1_actions=$(echo "$phase1_actions" | jq \
      --arg r "$ref" --arg n "$local_name" --argjson e "$executed" --argjson d "$DRY_RUN" \
      '. += [{"action":"close_crashed","ref":$r,"name":$n,"executed":$e,"dry_run":$d}]')
  fi
  i=$((i + 1))
done

jq -n --argjson actions "$phase1_actions" '{"phase":"auto_cleanup","actions":$actions}'
echo "---PHASE_SEPARATOR---"

# === PHASE 2: Idle + Waiting sessions ===
phase2_sessions="[]"

i=0
while [[ $i -lt $WS_COUNT ]]; do
  ref=$(ws_get $i $_REF)
  local_state=$(ws_get $i $_STATE)

  if is_current_ws "$ref"; then
    i=$((i + 1)); continue
  fi

  if [[ "$local_state" == "IDLE" ]] || [[ "$local_state" == "WAITING" ]]; then
    local_name=$(ws_get $i $_NAME)
    local_branch=$(ws_get $i $_BRANCH)
    local_cat=$(ws_get $i $_CAT)

    phase2_sessions=$(echo "$phase2_sessions" | jq \
      --arg r "$ref" --arg n "$local_name" --arg s "$local_state" \
      --arg b "$local_branch" --arg c "$local_cat" \
      '. += [{"ref":$r,"name":$n,"state":$s,"branch":$b,"category":$c}]')
  fi
  i=$((i + 1))
done

jq -n --argjson sessions "$phase2_sessions" '{"phase":"idle_cleanup","sessions":$sessions}'
echo "---PHASE_SEPARATOR---"

# === PHASE 3: Reorganize ===
window_count=$(cmux list-windows 2>/dev/null | wc -l | tr -d ' ')
single_window_warning=false
[[ "$window_count" -le 1 ]] && single_window_warning=true

phase3_changes="[]"

i=0
while [[ $i -lt $WS_COUNT ]]; do
  ref=$(ws_get $i $_REF)
  local_state=$(ws_get $i $_STATE)

  if is_current_ws "$ref"; then
    i=$((i + 1)); continue
  fi

  if [[ "$local_state" == "CRASHED" ]] || [[ "$local_state" == "UNKNOWN" ]]; then
    i=$((i + 1)); continue
  fi

  local_name=$(ws_get $i $_NAME)
  local_cat=$(ws_get $i $_CAT)

  if echo "$local_name" | grep -q '^\['; then
    i=$((i + 1)); continue
  fi

  proposed_name="$local_cat $local_name"
  case "$local_cat" in
    "[DEV]") target_window="Active Dev" ;;
    "[OPS]") target_window="Ops/Debug" ;;
    *)       target_window="Research" ;;
  esac

  phase3_changes=$(echo "$phase3_changes" | jq \
    --arg r "$ref" --arg cn "$local_name" --arg pn "$proposed_name" \
    --arg c "$local_cat" --arg tw "$target_window" \
    '. += [{"ref":$r,"current_name":$cn,"proposed_name":$pn,"category":$c,"target_window":$tw}]')

  i=$((i + 1))
done

jq -n --argjson sw "$single_window_warning" --argjson changes "$phase3_changes" \
  '{"phase":"reorganize","single_window_warning":$sw,"changes":$changes}'
